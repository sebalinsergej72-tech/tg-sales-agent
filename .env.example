# Server
PORT=8787
BASE_URL=https://your-public-domain.example
DATA_PATH=./data/db.json

# Telegram manager bot
# Create a bot in @BotFather, enable Bot Management Mode, then put its token here.
MANAGER_BOT_TOKEN=123456:replace-me
MANAGER_BOT_USERNAME=YourManagerBot
TELEGRAM_WEBHOOK_SECRET=change-this-webhook-secret
TELEGRAM_POLLING=true
TELEGRAM_POLL_TIMEOUT=25

# Optional OpenAI-powered reply generation. Without it, the local deterministic
# sales-agent policy still works for demos and pilots.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Optional OpenRouter-compatible setup.
# OpenRouter supports the OpenAI chat completions format at
# https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost:8787
OPENROUTER_TITLE=TG Sales Agent

# Optional encryption key for managed bot tokens.
# Use 32+ random bytes, e.g. `openssl rand -base64 32`.
ENCRYPTION_KEY=

# Optional outbound integrations
DEFAULT_SHEET_WEBHOOK_URL=
DEFAULT_CRM_WEBHOOK_URL=
